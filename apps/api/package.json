{
  "name": "@kubeasy/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./app-type": "./src/app-type.ts"
  },
  "scripts": {
    "dev": "PORT=$(turbo get-mfe-port) tsx --env-file=.env --watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "openapi:generate": "SKIP_ENV_CHECK=true tsx scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@appsignal/opentelemetry-instrumentation-bullmq": "0.8.0",
    "@better-auth/api-key": "catalog:",
    "@better-auth/drizzle-adapter": "1.6.9",
    "@hono/node-server": "1.19.14",
    "@hono/otel": "1.1.1",
    "@hono/standard-validator": "0.2.2",
    "@kubeasy/api-schemas": "workspace:*",
    "@kubeasy/jobs": "workspace:*",
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/core": "catalog:",
    "@opentelemetry/exporter-logs-otlp-http": "catalog:",
    "@opentelemetry/exporter-metrics-otlp-http": "catalog:",
    "@opentelemetry/exporter-trace-otlp-http": "catalog:",
    "@opentelemetry/instrumentation-http": "catalog:",
    "@opentelemetry/instrumentation-ioredis": "0.65.0",
    "@opentelemetry/instrumentation-pg": "0.69.0",
    "@opentelemetry/instrumentation-runtime-node": "catalog:",
    "@opentelemetry/resources": "catalog:",
    "@opentelemetry/sdk-logs": "catalog:",
    "@opentelemetry/sdk-metrics": "catalog:",
    "@opentelemetry/sdk-node": "catalog:",
    "@opentelemetry/semantic-conventions": "1.40.0",
    "@scalar/hono-api-reference": "0.10.14",
    "better-all": "0.0.7",
    "better-auth": "catalog:",
    "bullmq": "catalog:",
    "drizzle-orm": "0.45.2",
    "evlog": "catalog:",
    "hono": "catalog:",
    "hono-openapi": "1.3.0",
    "ioredis": "5.10.1",
    "nanoid": "5.1.11",
    "pg": "catalog:",
    "posthog-node": "5.33.3",
    "resend": "6.12.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@kubeasy/typescript-config": "workspace:*",
    "@types/node": "22.19.17",
    "@types/pg": "8.20.0",
    "@vitest/ui": "4.1.5",
    "drizzle-kit": "0.31.10",
    "openapi-types": "12.1.3",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  }
}
