{
  "name": "@kubeasy/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "PORT=$(turbo get-mfe-port) tsx --env-file=.env --watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "openapi:generate": "SKIP_ENV_CHECK=true tsx scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@appsignal/opentelemetry-instrumentation-bullmq": "0.8.0",
    "@better-auth/api-key": "1.6.9",
    "@better-auth/drizzle-adapter": "1.6.9",
    "@hono/node-server": "1.19.14",
    "@hono/otel": "1.1.1",
    "@hono/zod-openapi": "1.3.0",
    "@hono/zod-validator": "0.7.6",
    "@kubeasy/api-schemas": "workspace:*",
    "@kubeasy/jobs": "workspace:*",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/core": "2.7.1",
    "@opentelemetry/exporter-logs-otlp-http": "0.216.0",
    "@opentelemetry/exporter-metrics-otlp-http": "0.216.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.216.0",
    "@opentelemetry/instrumentation-http": "0.216.0",
    "@opentelemetry/instrumentation-ioredis": "0.64.0",
    "@opentelemetry/instrumentation-pg": "0.68.0",
    "@opentelemetry/instrumentation-runtime-node": "0.29.0",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-logs": "0.216.0",
    "@opentelemetry/sdk-metrics": "2.7.1",
    "@opentelemetry/sdk-node": "0.216.0",
    "@opentelemetry/semantic-conventions": "1.40.0",
    "better-all": "0.0.7",
    "better-auth": "1.6.9",
    "bullmq": "5.76.4",
    "drizzle-orm": "0.45.2",
    "evlog": "^2.14.0",
    "hono": "4.12.15",
    "ioredis": "5.10.1",
    "nanoid": "5.1.9",
    "pg": "8.20.0",
    "posthog-node": "5.31.0",
    "resend": "6.12.2",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@kubeasy/typescript-config": "workspace:*",
    "@types/node": "22.19.17",
    "@types/pg": "8.20.0",
    "@vitest/ui": "4.1.5",
    "drizzle-kit": "0.31.10",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  }
}
