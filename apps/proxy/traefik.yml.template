entryPoints:
  web:
    address: ":${PORT}"

# Enable ping internal service with automatic routing
ping:
  entryPoint: web

providers:
  file:
    filename: "${DYNAMIC_CONFIG_PATH}"
    watch: true

log:
  level: DEBUG

accessLog:
  format: json

# Enable tracing but ensure syntax is correct for v3
tracing:
  otlp:
    grpc:
      endpoint: "${OTEL_COLLECTOR_GRPC_UPSTREAM}"
      insecure: true

# Disable dashboard and API to avoid port conflicts
api:
  dashboard: false
  insecure: false
