entryPoints:
  web:
    address: ":${PORT}"

ping:
  entryPoint: web

providers:
  file:
    filename: "/etc/traefik/dynamic.yml"
    watch: true

log:
  level: INFO

accessLog:
  format: json

tracing:
  otlp:
    grpc:
      endpoint: "${OTEL_COLLECTOR_GRPC_UPSTREAM}"
      insecure: true

# Disable dashboard
api:
  dashboard: false
