# Kubeasy Production Reverse Proxy
# Upstream addresses injected via Railway env vars at runtime.
# Local dev uses Turborepo MFE proxy (microfrontends.json), not this file.
{
	admin off
}

:8080 {
	# Internal healthcheck — responds without hitting any upstream
	handle /healthz {
		respond "OK" 200
	}

	# OTLP Proxy — Exposes the collector to the browser via the main domain to avoid CORS
	@otlp path /instrumentation/*
	handle @otlp {
		uri strip_prefix /instrumentation
		reverse_proxy {$OTEL_COLLECTOR_UPSTREAM:otel-collector:4318}
	}

	# API routes — SSE requires immediate flush for real-time validation updates
	@api path /api /api/*
	handle @api {
		reverse_proxy {$API_UPSTREAM} {
			flush_interval -1
		}
	}

	# Docs route
	@docs path /docs /docs/*
	handle @docs {
		reverse_proxy {$DOCS_UPSTREAM}
	}

	# Admin SPA — served from static files
	@admin path /admin /admin/*
	handle @admin {
		uri strip_prefix /admin
		root * /admin

		# Add cache headers for static assets (mimics nginx.conf)
		@staticFiles path *.js *.css *.woff2 *.png *.svg *.ico
		header @staticFiles Cache-Control "public, max-age=31536000, immutable"

		# SPA support: try to find file, then directory, finally fallback to index.html
		try_files {path} {path}/ /index.html
		file_server
	}

	# Web app — catch-all for all other routes
	handle {
		reverse_proxy {$WEB_UPSTREAM}
	}
}

:2019 {
	metrics /metrics
}
