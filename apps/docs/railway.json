{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm exec turbo run build --filter=@kubeasy/docs",
    "watchPatterns": ["apps/docs/**", "packages/**"]
  },
  "deploy": {
    "startCommand": "cd apps/docs && npx next start -H 0.0.0.0",
    "healthcheckPath": "/docs",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
