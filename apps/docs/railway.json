{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/docs/Dockerfile",
    "watchPatterns": ["apps/docs/**"]
  },
  "deploy": {
    "healthcheckPath": "/docs",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
