{
  "name": "kubeasy-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "start": "turbo run start --filter=./apps/*",
    "dev": "turbo dev --filter=./apps/*",
    "dev:infra": "docker compose up -d",
    "typecheck": "turbo run typecheck",
    "check": "biome check .",
    "check:unsafe": "biome check --write --unsafe .",
    "check:write": "biome check --write .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "prepare": "husky",
    "knip": "dotenv -e .env.local -- knip"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/node": "24.12.0",
    "@vitest/ui": "4.1.0",
    "dotenv-cli": "11.0.0",
    "husky": "9.1.7",
    "knip": "5.86.0",
    "lint-staged": "16.3.3",
    "turbo": "^2.8.17",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "packageManager": "pnpm@10.32.1",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "biome check --write --unsafe --files-ignore-unknown=true --no-errors-on-unmatched"
    ],
    "*.{json,css}": [
      "biome check --write --files-ignore-unknown=true --no-errors-on-unmatched"
    ]
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    },
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "core-js",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
