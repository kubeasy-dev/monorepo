{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "envMode": "loose",
  "globalEnv": ["DATABASE_URL", "REDIS_URL", "BETTER_AUTH_SECRET"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", ".output/**"],
      "env": [
        "VITE_API_URL",
        "NOTION_INTEGRATION_TOKEN",
        "NOTION_BLOG_DATASOURCE_ID",
        "NOTION_DIRECTORY_DATASOURCE_ID",
        "NOTION_PEOPLE_DATASOURCE_ID"
      ]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    }
  }
}
